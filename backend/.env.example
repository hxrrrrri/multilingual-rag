# ── App ───────────────────────────────────────────────
APP_NAME=multilingual-rag
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ── Database ──────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@localhost:5432/ragdb

# ── Qdrant ────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=multilingual_docs

# ── Elasticsearch ─────────────────────────────────────
ES_HOST=http://localhost:9200
ES_INDEX=multilingual_docs

# ── Redis (Celery broker) ─────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM ───────────────────────────────────────────────
# Option A: OpenAI-compatible (vLLM, Ollama, OpenAI)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3

# Option B: OpenAI directly
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ── Embeddings ────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large
# Path to LoRA adapter (leave empty to use base model)
LORA_ADAPTER_PATH=

# ── Reranker ──────────────────────────────────────────
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── NLI Faithfulness Checker ──────────────────────────
NLI_MODEL=cross-encoder/nli-deberta-v3-small

# ── Retrieval ─────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
RRF_K=60

# ── MLFlow ────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT=multilingual-rag

# ── File Storage ──────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
